{
  "name": "drafter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "IR-centric UI design tool. Lay out any single screen in a GUI, compile it to code (HTML now), and hand the design.json to AI as a precise visual spec.",
  "keywords": ["design-tool", "ui-design", "wireframe", "figma-alternative", "low-code", "codegen", "html", "ai", "design-to-code", "intermediate-representation"],
  "license": "MIT",
  "author": "Naoya Yokota",
  "repository": { "type": "git", "url": "https://github.com/naoya-yokota/drafter.git" },
  "homepage": "https://github.com/naoya-yokota/drafter#readme",
  "bugs": { "url": "https://github.com/naoya-yokota/drafter/issues" },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "validate": "node scripts/validate-templates.mjs",
    "mcp": "node mcp/server.ts",
    "gen": "node src/cli.ts",
    "gen:example": "node src/cli.ts examples/design.json out",
    "check": "node src/cli.ts examples/design.json out --check"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
